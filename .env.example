# Enable Banking API sync
#
# 1. Register an application in Enable Banking Control Panel.
# 2. Put the application ID below.
# 3. Put the private RSA key in one of:
#    - ENABLE_BANKING_PRIVATE_KEY_BASE64 (recommended for .env)
#    - ENABLE_BANKING_PRIVATE_KEY_PEM (with \n line breaks)
#    - ENABLE_BANKING_PRIVATE_KEY_PATH (path to a gitignored .pem file)
#   (I recommend just using key path)
#
# Production API:
# ENABLE_BANKING_API_BASE_URL=https://api.enablebanking.com

ENABLE_BANKING_API_BASE_URL=https://api.enablebanking.com
ENABLE_BANKING_APPLICATION_ID=
ENABLE_BANKING_PRIVATE_KEY_BASE64=
ENABLE_BANKING_PRIVATE_KEY_PEM=
ENABLE_BANKING_PRIVATE_KEY_PATH=

# JWT generated for Enable Banking requests. Docs allow max 86400 seconds.
ENABLE_BANKING_JWT_TTL_SECONDS=3600

# Account transaction fetch settings.
ENABLE_BANKING_TRANSACTION_STATUS=BOOK
ENABLE_BANKING_MAX_PAGES=200

# Optional PSU context headers (ONLINE fetching only).
#
# Leave these EMPTY for normal server-side syncs. Enable Banking treats requests
# without PSU headers as "background" fetches, which is what this app does.

ENABLE_BANKING_PSU_IP_ADDRESS=
ENABLE_BANKING_PSU_USER_AGENT=
ENABLE_BANKING_PSU_REFERER=
ENABLE_BANKING_PSU_ACCEPT=
ENABLE_BANKING_PSU_ACCEPT_CHARSET=
ENABLE_BANKING_PSU_ACCEPT_ENCODING=
ENABLE_BANKING_PSU_ACCEPT_LANGUAGE=
ENABLE_BANKING_PSU_GEO_LOCATION=
